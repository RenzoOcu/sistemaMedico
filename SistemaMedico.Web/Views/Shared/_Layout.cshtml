@using Microsoft.AspNetCore.Authentication.Cookies
@using System.Security.Claims
@{
    var isAuthenticated = User.Identity?.IsAuthenticated;
    var rol = User.FindFirst(ClaimTypes.Role)?.Value;
}

<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Citas Médicas</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
<style>
        .navbar-toggler {
            border: 2px solid var(--accent-yellow);
            padding: 0.5rem;
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 0.2rem rgba(255, 215, 0, 0.25);
        }

        .navbar-toggler-icon {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 30 30'%3e%3cpath stroke='rgba%28255, 215, 0, 1%29' stroke-linecap='round' stroke-miterlimit='10' stroke-width='2' d='M4 7h22M4 15h22M4 23h22'/%3e%3c/svg%3e");
        }

        .navbar-nav .nav-link {
            padding: 0.75rem 1rem !important;
            margin: 0.25rem 0;
            border-radius: 0.375rem;
        }

        .navbar-nav .nav-link:hover {
            background-color: rgba(255, 215, 0, 0.15);
        }

        .navbar-nav .nav-item {
            margin: 0.25rem 0;
        }

        .theme-icon::before {
            content: "☀️";
        }

        [data-theme="light"] .theme-icon::before {
            content: "🌙";
        }

        \u0040media (max-width: 768px) {
            .navbar-collapse {
                display: none;
                background: linear-gradient(135deg, #000000, #1a1a1a);
                padding: 1rem;
                border-radius: 0.5rem;
                margin-top: 0.5rem;
                border: 1px solid var(--accent-yellow);
            }

            .navbar-collapse.show {
                display: block;
            }

            .navbar-toggler {
                display: block;
            }

            .navbar-brand {
                font-size: 1rem;
            }
            
            .navbar-brand::before {
                font-size: 1.3rem;
            }

            .navbar-collapse {
                padding: 0.75rem;
            }

            .theme-toggle {
                width: 40px;
                height: 40px;
                font-size: 1.1rem;
                bottom: 10px;
                right: 20px;
            }
        }

        \u0040media (min-width: 769px) {
            .navbar-collapse {
                display: flex !important;
            }

            .navbar-toggler {
                display: none;
            }
        }

        \u0040media (max-width: 576px) {
            .navbar-brand {
                font-size: 1rem;
            }
            
            .navbar-brand::before {
                font-size: 1.3rem;
            }

            .navbar-collapse {
                padding: 0.75rem;
            }

            .theme-toggle {
                width: 40px;
                height: 40px;
                font-size: 1.1rem;
                bottom: 10px;
                right: 20px;
            }
        }
    </style>
</head>
<body>
    @if (isAuthenticated == true)
    {
        <header>
            <nav class="navbar navbar-expand-md navbar-toggleable-sm navbar-dark border-bottom box-shadow mb-0">
                <div class="container-fluid">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="fas fa-hospital-user me-2"></i><span class="d-none d-sm-inline">SISTEMA MÉDICO</span>
                    </a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-md-flex" id="navbarContent">
                        <ul class="navbar-nav flex-grow-1">
                            @if (rol == "Recepcionista")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Pacientes" asp-action="Index">
                                        <i class="fas fa-users me-1"></i> <span class="d-inline d-md-none">Pacientes</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Citas" asp-action="Create">
                                        <i class="fas fa-calendar-plus me-1"></i> <span class="d-inline d-md-none">Nueva Cita</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Citas" asp-action="Index">
                                        <i class="fas fa-list me-1"></i> <span class="d-inline d-md-none">Citas</span>
                                    </a>
                                </li>
                            }
                            @if (rol == "Medico")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Citas" asp-action="MisCitas">
                                        <i class="fas fa-list me-1"></i> Mis Citas
                                    </a>
                                </li>
                            }
                        </ul>
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <span class="nav-link"><i class="fas fa-user-circle me-1"></i> <span class="d-none d-md-inline">@User.Identity?.Name</span></span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-1"></i> <span class="d-inline d-md-none">Salir</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }
    <div class="container-fluid p-0">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
        </div>
    </footer>

    <button class="theme-toggle" id="themeToggle" onclick="toggleTheme(); playClickSound()" title="Cambiar tema">
        <span class="theme-icon"></span>
    </button>

    <script>
        function playClickSound() {
            try {
                var audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                var oscillator = audioCtx.createOscillator();
                var gainNode = audioCtx.createGain();
                
                oscillator.connect(gainNode);
                gainNode.connect(audioCtx.destination);
                
                oscillator.frequency.value = 800;
                oscillator.type = 'sine';
                
                gainNode.gain.setValueAtTime(0.15, audioCtx.currentTime);
                gainNode.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.1);
                
                oscillator.start(audioCtx.currentTime);
                oscillator.stop(audioCtx.currentTime + 0.1);
            } catch(e) {}
        }
        
        function toggleTheme() {
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme');
            const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
            updateThemeIcon(newTheme);
        }
        
        function updateThemeIcon(theme) {
            const icon = document.querySelector('.theme-icon');
            if (icon) {
                if (theme === 'dark') {
                    icon.textContent = '☀️';
                } else {
                    icon.textContent = '🌙';
                }
            }
        }
        
        function initTheme() {
            const savedTheme = localStorage.getItem('theme') || 'dark';
            document.documentElement.setAttribute('data-theme', savedTheme);
            updateThemeIcon(savedTheme);
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            initTheme();
            
            document.addEventListener('click', function(e) {
                if (e.target.tagName === 'BUTTON' || e.target.closest('button') || 
                    e.target.tagName === 'A' || e.target.closest('a')) {
                    playClickSound();
                }
            });
        });
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>