@model IEnumerable<SistemaMedico.Application.DTOs.CitaDto>
@{
    ViewData["Title"] = "Mis Citas";
    Layout = "_Layout";
}

@functions {
    string GetEstadoColor(string estado)
    {
        return estado switch
        {
            "Programada" => "primary",
            "Atendida" => "success",
            "Cancelada" => "danger",
            _ => "secondary"
        };
    }
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="mb-1">Mis Citas</h2>
        @if (ViewBag.Medico != null)
        {
            <p class="text-muted mb-0 small">Dr(a). @ViewBag.Medico.Nombre - @ViewBag.Medico.Especialidad</p>
        }
    </div>
</div>

@if (ViewBag.Advertencia != null)
{
    <div class="alert alert-warning">⚠️ @ViewBag.Advertencia</div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">✗ @ViewBag.Error</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">✗ @TempData["Error"]</div>
}

<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="fas fa-search me-1"></i> Filtros de Búsqueda</h5>
    </div>
    <div class="card-body">
        <form method="post" asp-controller="Citas" asp-action="MisCitas" class="row g-3">
            <div class="col-6 col-md-3">
                <label class="form-label">Fecha Específica</label>
                <input type="date" class="form-control" name="Fecha" value="@(ViewBag.Filtros?.Fecha?.ToString("yyyy-MM-dd"))">
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" class="form-control" name="FechaInicio" value="@(ViewBag.Filtros?.FechaInicio?.ToString("yyyy-MM-dd"))">
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label">Fecha Fin</label>
                <input type="date" class="form-control" name="FechaFin" value="@(ViewBag.Filtros?.FechaFin?.ToString("yyyy-MM-dd"))">
            </div>
            <div class="col-6 col-md-3">
                <label class="form-label">Estado</label>
                <select class="form-select" name="Estado">
                    <option value="">Todos</option>
                    <option value="Programada" selected="@(ViewBag.Filtros?.Estado == "Programada")">Programada</option>
                    <option value="Atendida" selected="@(ViewBag.Filtros?.Estado == "Atendida")">Atendida</option>
                    <option value="Cancelada" selected="@(ViewBag.Filtros?.Estado == "Cancelada")">Cancelada</option>
                </select>
            </div>
            <div class="col-12 col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i> Buscar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
            <table class="table table-striped table-hover mb-0" style="min-width: 700px;">
                <thead>
                    <tr>
                        <th style="white-space: nowrap;">📅 Fecha</th>
                        <th style="white-space: nowrap;">🕐 Hora</th>
                        <th style="white-space: nowrap;">👤 Paciente</th>
                        <th style="white-space: nowrap;">📄 Documento</th>
                        <th style="white-space: nowrap;">🏥 Especialidad</th>
                        <th style="white-space: nowrap;">📝 Motivo</th>
                        <th style="white-space: nowrap;">⚡ Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td style="white-space: nowrap;">@cita.Fecha.ToString("dd/MM/yyyy")</td>
                            <td style="white-space: nowrap;">@cita.Hora.ToString(@"hh\:mm")</td>
                            <td style="white-space: nowrap;"><strong>@cita.NombrePaciente</strong></td>
                            <td style="white-space: nowrap;">@cita.NumeroDocumento</td>
                            <td style="white-space: nowrap;">@cita.Especialidad</td>
                            <td style="white-space: nowrap; max-width: 150px; overflow: hidden; text-overflow: ellipsis;" title="@cita.Motivo">@cita.Motivo</td>
                            <td style="white-space: nowrap;">
                                <span class="badge bg-@GetEstadoColor(cita.Estado)">@cita.Estado</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any() && ViewBag.Advertencia == null && ViewBag.Error == null)
{
    <div class="alert alert-info mt-4">
        <i class="fas fa-info-circle"></i> No se encontraron citas con los filtros seleccionados.
    </div>
}