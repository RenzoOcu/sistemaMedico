@model IEnumerable<SistemaMedico.Application.DTOs.CitaDto>
@{
    ViewData["Title"] = "Lista de Citas";
    Layout = "_Layout";
}

@functions {
    string GetEstadoColor(string estado)
    {
        return estado switch
        {
            "Programada" => "primary",
            "Atendida" => "success",
            "Cancelada" => "danger",
            _ => "secondary"
        };
    }
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="mb-1">Lista de Citas</h2>
        <p class="text-muted mb-0 small">Gestión de todas las citas médicas</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Nueva Cita
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">✗ @TempData["Error"]</div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
            <table class="table table-striped table-hover mb-0" style="min-width: 900px;">
                <thead>
                    <tr>
                        <th style="white-space: nowrap;">📅 Fecha</th>
                        <th style="white-space: nowrap;">🕐 Hora</th>
                        <th style="white-space: nowrap;">👤 Paciente</th>
                        <th style="white-space: nowrap;">📄 Documento</th>
                        <th style="white-space: nowrap;">👨‍⚕️ Médico</th>
                        <th style="white-space: nowrap;">🏥 Especialidad</th>
                        <th style="white-space: nowrap;">📝 Motivo</th>
                        <th style="white-space: nowrap;">⚡ Estado</th>
                        <th style="white-space: nowrap;">🗑️ Eliminar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td style="white-space: nowrap;">@cita.Fecha.ToString("dd/MM/yyyy")</td>
                            <td style="white-space: nowrap;">@cita.Hora.ToString(@"hh\:mm")</td>
                            <td style="white-space: nowrap;"><strong>@cita.NombrePaciente</strong></td>
                            <td style="white-space: nowrap;">@cita.NumeroDocumento</td>
                            <td style="white-space: nowrap;">@cita.NombreMedico</td>
                            <td style="white-space: nowrap;">@cita.Especialidad</td>
                            <td style="white-space: nowrap; max-width: 150px; overflow: hidden; text-overflow: ellipsis;" title="@cita.Motivo">@cita.Motivo</td>
                            <td style="white-space: nowrap;">
                                <span class="badge bg-@GetEstadoColor(cita.Estado)">@cita.Estado</span>
                            </td>
                            <td style="white-space: nowrap;">
                                <a asp-action="Delete" asp-route-id="@cita.IdCita" class="btn btn-sm btn-danger" title="Eliminar" onclick="return confirm('¿Está seguro de eliminar esta cita?')">🗑️</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-4">
        <i class="fas fa-info-circle"></i> No hay citas registradas.
    </div>
}