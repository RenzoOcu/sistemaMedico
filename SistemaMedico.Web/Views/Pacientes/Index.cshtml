@model IEnumerable<SistemaMedico.Application.DTOs.PacienteDto>
@{
    ViewData["Title"] = "Pacientes";
    Layout = "_Layout";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
    <div>
        <h2 class="mb-1">Gestión de Pacientes</h2>
        <p class="text-muted mb-0 small">Administra el registro de pacientes</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Nuevo Paciente
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">✓ @TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">✗ @TempData["Error"]</div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
            <table class="table table-striped table-hover mb-0" style="min-width: 800px;">
                <thead>
                    <tr>
                        <th style="white-space: nowrap;">📄 Documento</th>
                        <th style="white-space: nowrap;">👤 Nombre Completo</th>
                        <th style="white-space: nowrap;">📅 Fecha Nac.</th>
                        <th style="white-space: nowrap;">⚧ Sexo</th>
                        <th style="white-space: nowrap;">📞 Teléfono</th>
                        <th style="white-space: nowrap;">📧 Email</th>
                        <th style="white-space: nowrap;">⚙️ Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var paciente in Model)
                    {
                        <tr>
                            <td style="white-space: nowrap;">
                                <span class="badge bg-secondary">@paciente.TipoDocumento</span><br>
                                <strong>@paciente.NumeroDocumento</strong>
                            </td>
                            <td style="white-space: nowrap;">@paciente.Apellidos, @paciente.Nombres</td>
                            <td style="white-space: nowrap;">@paciente.FechaNacimiento.ToString("dd/MM/yyyy")</td>
                            <td style="white-space: nowrap;">@paciente.Sexo</td>
                            <td style="white-space: nowrap;">@paciente.Telefono</td>
                            <td style="white-space: nowrap;">@paciente.Email</td>
                            <td style="white-space: nowrap;">
                                <div class="d-flex gap-1">
                                    <a asp-action="Details" asp-route-id="@paciente.IdPaciente" class="btn btn-sm btn-info" title="Ver">👁️</a>
                                    <a asp-action="Edit" asp-route-id="@paciente.IdPaciente" class="btn btn-sm btn-warning" title="Editar">✏️</a>
                                    <a asp-action="Delete" asp-route-id="@paciente.IdPaciente" class="btn btn-sm btn-danger" title="Eliminar" onclick="return confirm('¿Está seguro de eliminar este paciente?')">🗑️</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-4">
        <i class="fas fa-info-circle"></i> No hay pacientes registrados.
    </div>
}